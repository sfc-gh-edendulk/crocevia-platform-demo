# Snowflake connection for the Node proxy (server/server.js). Copy to .env and fill in.
# These stay server-side; the React client never sees them.
SNOWFLAKE_ACCOUNT=MYORG-MYACCOUNT
SNOWFLAKE_USER=MY_USER
# Use ONE auth method:
SNOWFLAKE_PASSWORD=
# or key-pair:
# SNOWFLAKE_PRIVATE_KEY_PATH=/abs/path/key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=CR_DEV_WH
SNOWFLAKE_DATABASE=CROCEVIA_DB
SNOWFLAKE_SCHEMA=PLATFORM_DEMO
PORT=8787
